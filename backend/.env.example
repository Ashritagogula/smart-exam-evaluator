# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Database ────────────────────────────────────────────────────────────────────
# MongoDB connection string — use a separate database for tests (append _test)
MONGODB_URI=mongodb://username:password@host:27017/exam_management?authSource=admin
# Optional: override for test runs (CI/CD). If unset, globalSetup derives it from MONGODB_URI.
# MONGODB_TEST_URI=mongodb://username:password@host:27017/exam_management_test?authSource=admin

# ── Authentication ───────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# ── AI / OCR ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_google_gemini_api_key_here

# ── File Storage ─────────────────────────────────────────────────────────────────
UPLOAD_PATH=./uploads
OUTPUT_PATH=./output

# ── CORS ─────────────────────────────────────────────────────────────────────────
# Frontend origin — used for CORS allow-list
FRONTEND_URL=http://localhost:5173
